@startuml
set separator none
title Decentraal Berichtenmagazijn (per deelnemende organisatie) - Admin Dashboard - Components

top to bottom direction

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>
!include <C4/C4_Component>

Container(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOphaalAPI, "Berichtenmagazijn Ophaal API", $techn="Quarkus / Kotlin", $descr="REST API voor het ophalen van berichten en bijlagen", $tags="", $link="")
Container(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOpslaanAPI, "Berichtenmagazijn Opslaan API", $techn="Quarkus / Kotlin", $descr="REST API voor het opslaan van berichten door organisaties", $tags="", $link="")
System(LDVLogboek, "LDV Logboek", $descr="Logboek Dataverwerkingen - logging van dataverwerkingen conform LDV-standaard", $tags="", $link="")

Container_Boundary("DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard_boundary", "Admin Dashboard", $tags="") {
  Component(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard.VaadinViews, "Vaadin Views", $techn="Vaadin", $descr="Dashboard, Berichten, Systeemstatus en LDV Audit Log views", $tags="", $link="")
  Component(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard.DashboardDataService, "DashboardDataService", $techn="CDI Bean", $descr="Haalt berichtdata op via interne services", $tags="", $link="")
  Component(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard.ServiceHealthChecker, "ServiceHealthChecker", $techn="HTTP Client", $descr="Controleert beschikbaarheid van magazijndiensten", $tags="", $link="")
  Component(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard.LDVLogger, "LDV Logger", $techn="OpenTelemetry", $descr="Logt dataverwerkingen conform LDV-standaard", $tags="", $link="")
  Component(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard.ApplicatieLogger, "Applicatie Logger", $techn="SLF4J / Logback", $descr="Applicatie-logging (foutmeldingen, audit); buffert lokaal bij uitval logserver (max 72 uur)", $tags="", $link="")
}

Rel(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOphaalAPI, LDVLogboek, "Logt dataverwerkingen", $techn="OTLP", $tags="", $link="")
Rel(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOpslaanAPI, LDVLogboek, "Logt dataverwerkingen", $techn="OTLP", $tags="", $link="")
Rel(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard.LDVLogger, LDVLogboek, "Logt dataverwerkingen", $techn="OTLP", $tags="", $link="")
Rel(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard.VaadinViews, DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard.DashboardDataService, "Toont data van", $techn="", $tags="", $link="")
Rel(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard.VaadinViews, DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard.ServiceHealthChecker, "Toont status van", $techn="", $tags="", $link="")
Rel(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard.DashboardDataService, DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard.LDVLogger, "Logt verwerkingen", $techn="", $tags="", $link="")
Rel(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard.DashboardDataService, DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard.ApplicatieLogger, "Logt applicatie-events", $techn="", $tags="", $link="")
Rel(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard.DashboardDataService, DecentraalBerichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOphaalAPI, "Beheert berichten", $techn="Digikoppeling REST API via FSC", $tags="", $link="")
Rel(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard.ServiceHealthChecker, DecentraalBerichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOphaalAPI, "Controleert gezondheid", $techn="HTTP", $tags="", $link="")
Rel(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard.ServiceHealthChecker, DecentraalBerichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOpslaanAPI, "Controleert gezondheid", $techn="HTTP", $tags="", $link="")

SHOW_LEGEND(true)
