@startuml
set separator none
title Berichtenmagazijn (per deelnemende organisatie) - Containers

top to bottom direction

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>

System(NotificatieService, "Notificatie Service", $descr="Multi-channel notificatiebezorging via e-mail, SMS en app (MoZa)", $tags="", $link="")
System(DigitaleBereikbaarheidService, "Digitale Bereikbaarheid Service", $descr="Tonen en muteren toestemming voor digitale communicatie per organisatie", $tags="", $link="")
System(OrganisatieA, "Organisatie A", $descr="Deelnemende overheidsorganisatie - host zelf een berichtenmagazijn", $tags="", $link="")
System(OrganisatieB, "Organisatie B", $descr="Deelnemende overheidsorganisatie - neemt een berichtenmagazijn af bij BBO", $tags="", $link="")
System(BerichtenUitvraagSysteem, "Berichten Uitvraag Systeem", $descr="Centraal systeem voor het uitvragen, beheren en aanleveren van berichten in het Federatief Berichtenstelsel", $tags="", $link="")
System(LDVLogboek, "LDV Logboek", $descr="Logboek Dataverwerkingen - logging van dataverwerkingen conform LDV-standaard", $tags="", $link="")

System_Boundary("Berichtenmagazijnperdeelnemendeorganisatie_boundary", "Berichtenmagazijn (per deelnemende organisatie)", $tags="") {
  Container(Berichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOphaalAPI, "Berichtenmagazijn Ophaal API", $techn="Quarkus / Kotlin", $descr="REST API voor het ophalen van berichten en bijlagen", $tags="", $link="")
  Container(Berichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOpslaanAPI, "Berichtenmagazijn Opslaan API", $techn="Quarkus / Kotlin", $descr="REST API voor het opslaan van berichten door organisaties", $tags="", $link="")
  ContainerDb(Berichtenmagazijnperdeelnemendeorganisatie.Dataopslag, "Dataopslag", $techn="Naar keuze implementatie", $descr="Berichtmetadata, inhoud en bijlagen (0 berichtverlies)", $tags="", $link="")
  Container(Berichtenmagazijnperdeelnemendeorganisatie.BerichtValidatieService, "Bericht Validatie Service", $techn="Quarkus / Kotlin", $descr="Valideert berichten op technische eisen en controleert toestemming via Digitale Bereikbaarheid Service", $tags="", $link="")
  Container(Berichtenmagazijnperdeelnemendeorganisatie.PublicatieStream, "Publicatie Stream", $techn="Quarkus / Kotlin", $descr="Wacht met aanmelden van een bericht tot de publicatiedatum is verstreken (outbox-patroon voor gegarandeerde bezorging)", $tags="", $link="")
}

Rel(Berichtenmagazijnperdeelnemendeorganisatie.BerichtValidatieService, LDVLogboek, "Logt dataverwerkingen", $techn="OpenTelemetry (OTLP)", $tags="", $link="")
Rel(BerichtenUitvraagSysteem, LDVLogboek, "Logt dataverwerkingen", $techn="OpenTelemetry (OTLP)", $tags="", $link="")
Rel(Berichtenmagazijnperdeelnemendeorganisatie.PublicatieStream, LDVLogboek, "Logt dataverwerkingen", $techn="OpenTelemetry (OTLP)", $tags="", $link="")
Rel(Berichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOphaalAPI, Berichtenmagazijnperdeelnemendeorganisatie.Dataopslag, "Leest berichten en bijlagen", $techn="", $tags="", $link="")
Rel(Berichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOpslaanAPI, Berichtenmagazijnperdeelnemendeorganisatie.Dataopslag, "Schrijft berichten en bijlagen", $techn="", $tags="", $link="")
Rel(Berichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOpslaanAPI, Berichtenmagazijnperdeelnemendeorganisatie.BerichtValidatieService, "Stuurt bericht ter validatie", $techn="", $tags="", $link="")
Rel(Berichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOpslaanAPI, Berichtenmagazijnperdeelnemendeorganisatie.PublicatieStream, "Stuurt gevalideerd bericht door", $techn="", $tags="", $link="")
Rel(Berichtenmagazijnperdeelnemendeorganisatie.PublicatieStream, Berichtenmagazijnperdeelnemendeorganisatie.Dataopslag, "Leest berichten met status 'te publiceren' en werkt status bij na succesvolle aanmelding", $techn="", $tags="", $link="")
Rel(BerichtenUitvraagSysteem, Berichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOphaalAPI, "Haalt bijlagen op uit berichtenmagazijn", $techn="Digikoppeling REST API via FSC", $tags="", $link="")
Rel(Berichtenmagazijnperdeelnemendeorganisatie.PublicatieStream, BerichtenUitvraagSysteem, "Meldt nieuw bericht aan", $techn="Digikoppeling REST API via FSC", $tags="", $link="")
Rel(Berichtenmagazijnperdeelnemendeorganisatie.PublicatieStream, NotificatieService, "Stuurt bericht-events door", $techn="CloudEvents webhook", $tags="", $link="")
Rel(OrganisatieA, Berichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOpslaanAPI, "Levert berichten aan", $techn="Digikoppeling REST API via FSC", $tags="", $link="")
Rel(OrganisatieB, Berichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOpslaanAPI, "Levert berichten aan", $techn="Digikoppeling REST API via FSC", $tags="", $link="")
Rel(Berichtenmagazijnperdeelnemendeorganisatie.BerichtValidatieService, DigitaleBereikbaarheidService, "Controleert of de ontvanger toestemming gegeven heeft", $techn="Digikoppeling REST API via FSC", $tags="", $link="")
Rel(Berichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOphaalAPI, LDVLogboek, "Logt dataverwerkingen", $techn="OpenTelemetry (OTLP)", $tags="", $link="")
Rel(Berichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOpslaanAPI, LDVLogboek, "Logt dataverwerkingen", $techn="OpenTelemetry (OTLP)", $tags="", $link="")

SHOW_LEGEND(true)
@enduml