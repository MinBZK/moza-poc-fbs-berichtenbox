Rel(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOpslaanAPI, DecentraalBerichtenmagazijnperdeelnemendeorganisatie.BerichtValidatieService, "Stuurt bericht ter validatie", $techn="REST API", $tags="", $link="")
Rel(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard, DecentraalBerichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOphaalAPI, "Beheert berichten", $techn="REST API", $tags="", $link="")
Rel(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard, DecentraalBerichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOpslaanAPI, "Controleert gezondheid", $techn="HTTP", $tags="", $link="")
Rel(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOpslaanAPI, DecentraalBerichtenmagazijnperdeelnemendeorganisatie.PublicatieStream, "Stuurt gevalideerd bericht door", $techn="", $tags="", $link="")
Rel(BerichtenUitvraagSysteem, DecentraalBerichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOphaalAPI, "Haalt bijlagen op uit berichtenmagazijn", $techn="REST API", $tags="", $link="")
Rel(Beheerder, DecentraalBerichtenmagazijnperdeelnemendeorganisatie.AdminDashboard, "Beheert systeem via", $techn="HTTPS (browser)", $tags="", $link="")
Rel(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.PublicatieStream, BerichtenUitvraagSysteem, "Meldt nieuw bericht aan", $techn="REST API", $tags="", $link="")
Rel(DecentraalBerichtenmagazijnperdeelnemendeorganisatie.PublicatieStream, NotificatieService, "Stuurt bericht-events door", $techn="CloudEvents webhook", $tags="", $link="")
Rel(OrganisatieA, DecentraalBerichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOpslaanAPI, "Levert berichten aan", $techn="Digikoppeling REST API via FSC", $tags="", $link="")
Rel(OrganisatieB, DecentraalBerichtenmagazijnperdeelnemendeorganisatie.BerichtenmagazijnOpslaanAPI, "Levert berichten aan", $techn="Digikoppeling REST API via FSC", $tags="", $link="")

SHOW_LEGEND(true)
@enduml