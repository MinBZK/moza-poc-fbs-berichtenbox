!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>
!include <C4/C4_Component>

System(AuthZENFTV, "AuthZEN / FTV", $descr="Federatieve Toegangsverlening - autorisatie van verzoeken", $tags="", $link="")
System(DecentraalBerichtenmagazijnperdeelnemendeorganisatie, "Decentraal Berichtenmagazijn (per deelnemende organisatie)", $descr="Berichten opslaan en ophalen - elke deelnemende organisatie host een eigen instantie, of neemt er een af bij BBO", $tags="", $link="")
ContainerDb(BerichtenUitvraagSysteem.LokaleLogBuffer, "Lokale Log Buffer", $techn="Disk", $descr="Lokale opslag voor applicatie-logberichten bij onbeschikbaarheid logserver (max 72 uur retentie)", $tags="", $link="")
System(LDVLogboek, "LDV Logboek", $descr="Logboek Dataverwerkingen - logging van dataverwerkingen conform LDV-standaard", $tags="", $link="")

Container_Boundary("BerichtenUitvraagSysteem.Berichtensessiecache_boundary", "Berichtensessiecache", $tags="") {
  Component(BerichtenUitvraagSysteem.Berichtensessiecache.BerichtensessiecacheAPI, "Berichtensessiecache API", $techn="JAX-RS Resource", $descr="REST endpoints voor berichtensessiecache en zoeken", $tags="", $link="")
  Component(BerichtenUitvraagSysteem.Berichtensessiecache.BerichtensessiecacheService, "BerichtensessiecacheService", $techn="CDI Bean", $descr="Aggregeert en cachet berichten; filtert berichten op basis van autorisatie via FTV/AuthZEN", $tags="", $link="")
  Component(BerichtenUitvraagSysteem.Berichtensessiecache.Cache, "Cache", $techn="Caffeine", $descr="In-memory cache voor berichten (60s TTL)", $tags="", $link="")
  Component(BerichtenUitvraagSysteem.Berichtensessiecache.MagazijnClient, "MagazijnClient", $techn="REST Client", $descr="REST client naar decentrale berichtenmagazijnen", $tags="", $link="")
  Component(BerichtenUitvraagSysteem.Berichtensessiecache.LDVLogger, "LDV Logger", $techn="OpenTelemetry", $descr="Logt dataverwerkingen conform LDV-standaard", $tags="", $link="")
  Component(BerichtenUitvraagSysteem.Berichtensessiecache.ApplicatieLogger, "Applicatie Logger", $techn="SLF4J / Logback", $descr="Applicatie-logging (foutmeldingen, audit); buffert lokaal bij uitval logserver (max 72 uur)", $tags="", $link="")
}

Rel(BerichtenUitvraagSysteem.Berichtensessiecache.BerichtensessiecacheService, AuthZENFTV, "Filtert berichten op autorisatie", $techn="AuthZEN REST API", $tags="", $link="")
Rel(BerichtenUitvraagSysteem.Berichtensessiecache.MagazijnClient, DecentraalBerichtenmagazijnperdeelnemendeorganisatie, "Haalt berichten op", $techn="Digikoppeling REST API via FSC", $tags="", $link="")
Rel(DecentraalBerichtenmagazijnperdeelnemendeorganisatie, LDVLogboek, "Logt dataverwerkingen", $techn="OTLP", $tags="", $link="")
Rel(BerichtenUitvraagSysteem.Berichtensessiecache.LDVLogger, LDVLogboek, "Logt dataverwerkingen", $techn="OTLP", $tags="", $link="")
Rel(BerichtenUitvraagSysteem.Berichtensessiecache.BerichtensessiecacheAPI, BerichtenUitvraagSysteem.Berichtensessiecache.BerichtensessiecacheService, "Gebruikt", $techn="", $tags="", $link="")
Rel(BerichtenUitvraagSysteem.Berichtensessiecache.BerichtensessiecacheService, BerichtenUitvraagSysteem.Berichtensessiecache.Cache, "Leest/schrijft cache", $techn="", $tags="", $link="")
