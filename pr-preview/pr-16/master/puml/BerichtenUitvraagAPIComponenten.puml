@startuml
set separator none
title Berichten Uitvraag Systeem - Berichten Uitvraag API - Components

top to bottom direction

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>
!include <C4/C4_Component>

System(DecentraalBerichtenmagazijnperdeelnemendeorganisatie, "Decentraal Berichtenmagazijn (per deelnemende organisatie)", $descr="Berichten opslaan en ophalen - elke deelnemende organisatie host een eigen instantie, of neemt er een af bij BBO", $tags="", $link="")
Container(BerichtenUitvraagSysteem.Berichtensessiecache, "Berichtensessiecache", $techn="Quarkus / Kotlin", $descr="Aggregeert berichten uit alle aangesloten magazijnen voor een burger of zakelijke gebruiker", $tags="", $link="")
System(LDVLogboek, "LDV Logboek", $descr="Logboek Dataverwerkingen - logging van dataverwerkingen conform LDV-standaard", $tags="", $link="")

Container_Boundary("BerichtenUitvraagSysteem.BerichtenUitvraagAPI_boundary", "Berichten Uitvraag API", $tags="") {
  Component(BerichtenUitvraagSysteem.BerichtenUitvraagAPI.BerichtenlijstService, "Berichtenlijst Service", $techn="CDI Bean", $descr="Lever per map een berichtenlijst, verplaats berichten naar andere map, verwijder berichten", $tags="", $link="")
  Component(BerichtenUitvraagSysteem.BerichtenUitvraagAPI.OpvraagService, "Opvraag Service", $techn="CDI Bean", $descr="Haal berichten en bijlagen op; berichten uit cache, bijlagen uit berichtenmagazijn", $tags="", $link="")
}

Rel(BerichtenUitvraagSysteem.Berichtensessiecache, LDVLogboek, "Logt dataverwerkingen", $techn="OpenTelemetry (OTLP)", $tags="", $link="")
Rel(BerichtenUitvraagSysteem.BerichtenUitvraagAPI.BerichtenlijstService, LDVLogboek, "Logt dataverwerkingen", $techn="OpenTelemetry (OTLP)", $tags="", $link="")
Rel(BerichtenUitvraagSysteem.BerichtenUitvraagAPI.OpvraagService, LDVLogboek, "Logt dataverwerkingen", $techn="OpenTelemetry (OTLP)", $tags="", $link="")
Rel(BerichtenUitvraagSysteem.BerichtenUitvraagAPI.OpvraagService, BerichtenUitvraagSysteem.Berichtensessiecache, "Haalt berichten op uit cache", $techn="REST API (intern)", $tags="", $link="")
Rel(BerichtenUitvraagSysteem.BerichtenUitvraagAPI.BerichtenlijstService, BerichtenUitvraagSysteem.Berichtensessiecache, "Haalt berichtenlijst op", $techn="REST API (intern)", $tags="", $link="")
Rel(BerichtenUitvraagSysteem.BerichtenUitvraagAPI.OpvraagService, DecentraalBerichtenmagazijnperdeelnemendeorganisatie, "Haalt bijlagen op uit berichtenmagazijn", $techn="Digikoppeling REST API via FSC", $tags="", $link="")
Rel(BerichtenUitvraagSysteem.Berichtensessiecache, DecentraalBerichtenmagazijnperdeelnemendeorganisatie, "Haalt berichten op", $techn="Digikoppeling REST API via FSC", $tags="", $link="")
Rel(DecentraalBerichtenmagazijnperdeelnemendeorganisatie, LDVLogboek, "Logt dataverwerkingen", $techn="OpenTelemetry (OTLP)", $tags="", $link="")

SHOW_LEGEND(true)
@enduml