@startuml
set separator none
title Berichten Uitvraag Systeem - System Context

top to bottom direction
skinparam ranksep 60
skinparam nodesep 30

skinparam {
  arrowFontSize 10
  defaultTextAlignment center
  wrapWidth 200
  maxMessageSize 100
}

hide stereotype

skinparam rectangle<<BerichtenUitvraagSysteem>> {
  BackgroundColor #438dd5
  FontColor #ffffff
  BorderColor #2e6295
  shadowing false
}
skinparam rectangle<<Berichtenmagazijnperdeelnemendeorganisatie>> {
  BackgroundColor #2d8a4e
  FontColor #ffffff
  BorderColor #1e6b38
  shadowing false
}
skinparam rectangle<<DigiD>> {
  BackgroundColor #666666
  FontColor #ffffff
  BorderColor #0b4884
  shadowing false
}
skinparam rectangle<<Interactielaag>> {
  BackgroundColor #666666
  FontColor #ffffff
  BorderColor #0b4884
  shadowing false
}
skinparam queue<<LDVLogboek>> {
  BackgroundColor #999999
  FontColor #ffffff
  BorderColor #6b6b6b
  shadowing false
}
skinparam rectangle<<eHerkenning>> {
  BackgroundColor #666666
  FontColor #ffffff
  BorderColor #0b4884
  shadowing false
}

rectangle "Federatief Berichtenstelsel (FBS)" <<group1>> as group1 {
  skinparam RectangleBorderColor<<group1>> #cccccc
  skinparam RectangleFontColor<<group1>> #cccccc
  skinparam RectangleBorderStyle<<group1>> dashed

  rectangle "==Berichtenmagazijn (per deelnemende organisatie)\n<size:10>[Software System]</size>\n\nBerichten opslaan en ophalen" <<Berichtenmagazijnperdeelnemendeorganisatie>> as Berichtenmagazijnperdeelnemendeorganisatie
    rectangle "Centraal gehoste services" <<group2>> as group2 {
      skinparam RectangleBorderColor<<group2>> #cccccc
      skinparam RectangleFontColor<<group2>> #cccccc
      skinparam RectangleBorderStyle<<group2>> dashed

      rectangle "==Berichten Uitvraag Systeem\n<size:10>[Software System]</size>\n\nCentraal systeem voor het uitvragen, beheren en aanleveren van berichten in het Federatief Berichtenstelsel" <<BerichtenUitvraagSysteem>> as BerichtenUitvraagSysteem
      queue "==LDV Logboek\n<size:10>[Software System]</size>\n\nLogboek Dataverwerkingen - logging van dataverwerkingen conform LDV-standaard" <<LDVLogboek>> as LDVLogboek
    }

}

rectangle "==Interactielaag\n<size:10>[Software System]</size>\n\nPortaal of app waarmee burgers en ondernemers communiceren met het berichtenstelsel (b.v. MijnOverheid portaal, of andere portalen)" <<Interactielaag>> as Interactielaag
rectangle "==eHerkenning\n<size:10>[Software System]</size>\n\nAuthenticatie en machtigingen voor zakelijke gebruikers — SAML 2.0 stelsel met machtigingenvoorziening en dienstencatalogus" <<eHerkenning>> as eHerkenning
rectangle "==DigiD\n<size:10>[Software System]</size>\n\nAuthenticatie voor burgers" <<DigiD>> as DigiD

Berichtenmagazijnperdeelnemendeorganisatie .[#707070,thickness=2].> LDVLogboek : "<color:#707070>Logt dataverwerkingen\n<color:#707070><size:8>[OpenTelemetry (OTLP)]</size>"
BerichtenUitvraagSysteem .[#707070,thickness=2].> LDVLogboek : "<color:#707070>Logt dataverwerkingen\n<color:#707070><size:8>[OpenTelemetry (OTLP)]</size>"
BerichtenUitvraagSysteem .[#707070,thickness=2].> Berichtenmagazijnperdeelnemendeorganisatie : "<color:#707070>Wisselt berichten en bijlagen uit\n<color:#707070><size:8>[Digikoppeling REST API via FSC]</size>"
Interactielaag .[#707070,thickness=2].> BerichtenUitvraagSysteem : "<color:#707070>Berichten en metadata ophalen, bewerken en verwijderen\n<color:#707070><size:8>[Digikoppeling REST API via FSC (SAML-assertion als bearer token)]</size>"
Interactielaag .[#707070,thickness=2].> DigiD : "<color:#707070>Authenticatie burgers\n<color:#707070><size:8>[SAML 2.0]</size>"
Interactielaag .[#707070,thickness=2].> eHerkenning : "<color:#707070>Authenticatie zakelijke gebruikers; ontvangt gemachtigde diensten via SAML-assertion\n<color:#707070><size:8>[SAML 2.0]</size>"
BerichtenUitvraagSysteem .[#707070,thickness=2].> eHerkenning : "<color:#707070>Valideert SAML-assertion (backchannel)\n<color:#707070><size:8>[SAML Metadata (HTTPS)]</size>"
BerichtenUitvraagSysteem .[#707070,thickness=2].> DigiD : "<color:#707070>Valideert SAML-assertion (backchannel)\n<color:#707070><size:8>[SAML Metadata (HTTPS)]</size>"
@enduml