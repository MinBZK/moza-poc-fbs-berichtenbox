@startuml
set separator none
title Berichten Uitvraag Systeem - Containers

top to bottom direction

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>

System(AuthZENFTV, "AuthZEN / FTV", $descr="Federatieve Toegangsverlening - autorisatie van verzoeken", $tags="", $link="")
System(Interactielaag, "Interactielaag", $descr="Portaal of app waarmee burgers en ondernemers communiceren met het berichtenstelsel (b.v. MijnOverheid portaal, of andere portalen)", $tags="", $link="")
System(Berichtenmagazijnperdeelnemendeorganisatie, "Berichtenmagazijn (per deelnemende organisatie)", $descr="Berichten opslaan en ophalen", $tags="", $link="")
System(LDVLogboek, "LDV Logboek", $descr="Logboek Dataverwerkingen - logging van dataverwerkingen conform LDV-standaard", $tags="", $link="")

System_Boundary("BerichtenUitvraagSysteem_boundary", "Berichten Uitvraag Systeem", $tags="") {
  Container(BerichtenUitvraagSysteem.Berichtensessiecache, "Berichtensessiecache", $techn="Quarkus / Kotlin", $descr="Aggregeert berichten uit alle aangesloten magazijnen voor een burger of zakelijke gebruiker", $tags="", $link="")
  Container(BerichtenUitvraagSysteem.BerichtenUitvraagService, "Berichten Uitvraag Service", $techn="Quarkus / Kotlin", $descr="Service voor burgers en ondernemers - berichtenbox inzien en berichten beheren", $tags="", $link="")
  Container(BerichtenUitvraagSysteem.AanmeldService, "Aanmeld Service", $techn="Quarkus / Kotlin", $descr="Werkt de cache bij voor nieuwe berichten verzonden tijdens de sessie van de ontvanger", $tags="", $link="")
}

Rel(BerichtenUitvraagSysteem.Berichtensessiecache, LDVLogboek, "Logt dataverwerkingen", $techn="OpenTelemetry (OTLP)", $tags="", $link="")
Rel(BerichtenUitvraagSysteem.AanmeldService, LDVLogboek, "Logt dataverwerkingen", $techn="OpenTelemetry (OTLP)", $tags="", $link="")
Rel(BerichtenUitvraagSysteem.BerichtenUitvraagService, LDVLogboek, "Logt dataverwerkingen", $techn="OpenTelemetry (OTLP)", $tags="", $link="")
Rel(BerichtenUitvraagSysteem.AanmeldService, BerichtenUitvraagSysteem.Berichtensessiecache, "Werkt cache bij", $techn="REST API (intern)", $tags="", $link="")
Rel(BerichtenUitvraagSysteem.BerichtenUitvraagService, BerichtenUitvraagSysteem.Berichtensessiecache, "Haalt berichten op uit cache", $techn="REST API (intern)", $tags="", $link="")
Rel(Interactielaag, BerichtenUitvraagSysteem.BerichtenUitvraagService, "Berichten ophalen en lijsten", $techn="Digikoppeling REST API via FSC", $tags="", $link="")
Rel(BerichtenUitvraagSysteem.BerichtenUitvraagService, Berichtenmagazijnperdeelnemendeorganisatie, "Haalt bijlagen op uit berichtenmagazijn", $techn="Digikoppeling REST API via FSC", $tags="", $link="")
Rel(Berichtenmagazijnperdeelnemendeorganisatie, BerichtenUitvraagSysteem.AanmeldService, "Meldt nieuw bericht aan", $techn="Digikoppeling REST API via FSC", $tags="", $link="")
Rel(BerichtenUitvraagSysteem.Berichtensessiecache, AuthZENFTV, "Filtert berichten op autorisatie", $techn="AuthZEN REST API", $tags="", $link="")
Rel(BerichtenUitvraagSysteem.Berichtensessiecache, Berichtenmagazijnperdeelnemendeorganisatie, "Haalt berichten op", $techn="Digikoppeling REST API via FSC", $tags="", $link="")
Rel(Berichtenmagazijnperdeelnemendeorganisatie, LDVLogboek, "Logt dataverwerkingen", $techn="OpenTelemetry (OTLP)", $tags="", $link="")

SHOW_LEGEND(true)
@enduml