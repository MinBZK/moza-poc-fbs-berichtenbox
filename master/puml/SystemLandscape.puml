@startuml
set separator none
title System Landscape

top to bottom direction
skinparam ranksep 60
skinparam nodesep 30

skinparam {
  arrowFontSize 10
  defaultTextAlignment center
  wrapWidth 200
  maxMessageSize 100
}

hide stereotype

skinparam rectangle<<AuthZENFTV>> {
  BackgroundColor #666666
  FontColor #ffffff
  BorderColor #0b4884
  shadowing false
}
skinparam rectangle<<BerichtenUitvraagSysteem>> {
  BackgroundColor #438dd5
  FontColor #ffffff
  BorderColor #2e6295
  shadowing false
}
skinparam rectangle<<Berichtenmagazijnperdeelnemendeorganisatie>> {
  BackgroundColor #2d8a4e
  FontColor #ffffff
  BorderColor #1e6b38
  shadowing false
}
skinparam person<<Burger>> {
  BackgroundColor #08427b
  FontColor #ffffff
  BorderColor #052e56
  shadowing false
}
skinparam rectangle<<DigitaleBereikbaarheidService>> {
  BackgroundColor #666666
  FontColor #ffffff
  BorderColor #0b4884
  shadowing false
}
skinparam rectangle<<Interactielaag>> {
  BackgroundColor #666666
  FontColor #ffffff
  BorderColor #0b4884
  shadowing false
}
skinparam queue<<LDVLogboek>> {
  BackgroundColor #999999
  FontColor #ffffff
  BorderColor #6b6b6b
  shadowing false
}
skinparam person<<MedewerkerA>> {
  BackgroundColor #08427b
  FontColor #ffffff
  BorderColor #052e56
  shadowing false
}
skinparam person<<MedewerkerB>> {
  BackgroundColor #08427b
  FontColor #ffffff
  BorderColor #052e56
  shadowing false
}
skinparam rectangle<<NotificatieService>> {
  BackgroundColor #666666
  FontColor #ffffff
  BorderColor #0b4884
  shadowing false
}
skinparam person<<OndernemerZakelijkegebruiker>> {
  BackgroundColor #08427b
  FontColor #ffffff
  BorderColor #052e56
  shadowing false
}
skinparam rectangle<<OrganisatieA>> {
  BackgroundColor #8c8c8c
  FontColor #ffffff
  BorderColor #0b4884
  shadowing false
}
skinparam rectangle<<OrganisatieB>> {
  BackgroundColor #8c8c8c
  FontColor #ffffff
  BorderColor #0b4884
  shadowing false
}
