meta {
  name: 2. Bericht aanleveren (ontvanger OIN)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/berichten
  body: json
  auth: none
}

headers {
  traceparent: 00-{{traceId}}-{{parentSpanId}}-01
}

body:json {
  {
    "afzender": "{{afzender}}",
    "ontvanger": { "type": "OIN", "waarde": "{{ontvangerOrganisatie}}" },
    "onderwerp": "Jaarafrekening 2025",
    "inhoud": "Beste organisatie,\n\nHierbij ontvangt u uw jaarafrekening over 2025."
  }
}
