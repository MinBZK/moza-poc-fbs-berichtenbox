meta {
  name: 5. Bericht aanleveren - ongeldige ontvanger (400)
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/berichten
  body: json
  auth: none
}

headers {
  traceparent: 00-{{traceId}}-{{parentSpanId}}-01
}

body:json {
  {
    "afzender": "{{afzender}}",
    "ontvanger": { "type": "BSN", "waarde": "12345" },
    "onderwerp": "Ongeldige ontvanger",
    "inhoud": "Ontvanger-waarde voldoet niet aan de type-invarianten (BSN moet 9 cijfers + elfproef zijn)."
  }
}
