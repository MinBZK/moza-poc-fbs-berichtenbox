meta {
  name: 7. Bericht verwijderen
  type: http
  seq: 7
}

delete {
  url: {{baseUrlUitvraag}}/berichten/{{berichtId}}?magazijnId={{magazijnId}}
  auth: none
}

params:query {
  magazijnId: {{magazijnId}}
}

headers {
  X-Ontvanger: {{ontvangerHeaderPersoon}}
  traceparent: 00-{{traceId}}-{{parentSpanId}}-01
}
