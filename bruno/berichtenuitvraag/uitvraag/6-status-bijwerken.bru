meta {
  name: 6. Berichtstatus bijwerken (PATCH status + map)
  type: http
  seq: 6
}

patch {
  url: {{baseUrlUitvraag}}/berichten/{{berichtId}}?magazijnId={{magazijnId}}
  body: json
  auth: none
}

params:query {
  magazijnId: {{magazijnId}}
}

headers {
  X-Ontvanger: {{ontvangerHeaderPersoon}}
  Content-Type: application/merge-patch+json
  traceparent: 00-{{traceId}}-{{parentSpanId}}-01
}

body:json {
  {
    "status": "gelezen",
    "map": "archief"
  }
}
