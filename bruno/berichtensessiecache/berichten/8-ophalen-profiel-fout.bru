meta {
  name: 8. Ophalen met Profiel-503-pad
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/berichten/_ophalen
  body: none
  auth: none
}

headers {
  X-Ontvanger: BSN:999991401
  traceparent: 00-{{traceId}}-{{parentSpanId}}-01
}

assert {
  res.status: eq 503
  res.headers["Retry-After"]: eq "30"
}
