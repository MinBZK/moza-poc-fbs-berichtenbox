<?xml version="1.0"?>
<!--
  Geheugen-cap voor ClickHouse als kleine ephemeral LDV-component op ZAD.

  Probleem: in de container leest de stock-server soms het host-RAM i.p.v. de cgroup-
  limit; met de default ratio (0.9 van "RAM") zet het zijn interne limit veel te hoog en
  wordt het proces door de cgroup OOM-gekild. De caches (mark_cache default 5 GiB!) groeien
  daarbij lazy mee.

  Oplossing: een ABSOLUTE geheugen-cap (defeat de RAM-misdetectie) + kleine caches + lage
  background-pools. Afgestemd op een container-limit van ~768Mi–1Gi. Lager limit gewenst?
  Verlaag max_server_memory_usage navenant en herbouw het image.
-->
<clickhouse>
    <!-- Harde absolute cap (bytes): 512 MiB tracked geheugen, los van gedetecteerd RAM. -->
    <max_server_memory_usage>536870912</max_server_memory_usage>

    <!-- Caches klein i.p.v. de multi-GiB defaults (LDV-load is licht). -->
    <mark_cache_size>67108864</mark_cache_size>          <!-- 64 MiB (default 5 GiB) -->
    <uncompressed_cache_size>0</uncompressed_cache_size>
    <mmap_cache_size>0</mmap_cache_size>
    <compiled_expression_cache_size>0</compiled_expression_cache_size>

    <!-- Background-pools minimaliseren: elke thread reserveert stack/geheugen. -->
    <background_pool_size>2</background_pool_size>
    <background_schedule_pool_size>2</background_schedule_pool_size>
    <background_common_pool_size>2</background_common_pool_size>
    <background_message_broker_schedule_pool_size>1</background_message_broker_schedule_pool_size>
    <background_distributed_schedule_pool_size>1</background_distributed_schedule_pool_size>

    <!-- Met background_pool_size=2 is de mutation/merge-pool = 2 * concurrency_ratio(2) = 4.
         ClickHouse's sanity-check eist dat ALLE drie 'number_of_free_entries_in_pool_to_*'-
         drempels <= pool*ratio zijn; de defaults (20, 8, 25) > 4 → abort bij start
         (BAD_ARGUMENTS, Code 36). Verlaag alle drie onder pool*ratio zodat mutaties/merges/
         optimize werken bij kleine pools. -->
    <merge_tree>
        <number_of_free_entries_in_pool_to_execute_mutation>2</number_of_free_entries_in_pool_to_execute_mutation>
        <number_of_free_entries_in_pool_to_lower_max_size_of_merge>2</number_of_free_entries_in_pool_to_lower_max_size_of_merge>
        <number_of_free_entries_in_pool_to_execute_optimize_entire_partition>2</number_of_free_entries_in_pool_to_execute_optimize_entire_partition>
    </merge_tree>

    <max_concurrent_queries>8</max_concurrent_queries>

    <!-- console=1: schrijf óók naar stdout. Anders gaat de fatale fout alleen naar
         /var/log/clickhouse-server/*.err.log in de container en blijft 'kubectl logs' leeg. -->
    <logger>
        <level>warning</level>
        <console>1</console>
    </logger>
</clickhouse>
